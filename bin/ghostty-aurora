#!/usr/bin/env node

import { mkdir, readFile, rename, rm, writeFile } from "node:fs/promises";
import path from "node:path";
import { fileURLToPath } from "node:url";
import { findVariant, variantIds, variants } from "../src/variants.mjs";

const root = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..");
const configDir = path.join(root, "config");
const configPath = path.join(configDir, "ghostty-aurora.conf");
const activeShaderPath = path.join(configDir, "active.glsl");

function usage() {
  const idList = variantIds().join("|");

  return [
    "Usage: ghostty-aurora <command>",
    "",
    "Commands:",
    "  list                         List available variants",
    "  current                      Print the active variant",
    `  use ${idList} [--intensity N] [--minutes N]`,
    "                               Switch the Ghostty shader fragment",
    "  intensity get                Print the active intensity",
    "  intensity set N              Set a local intensity override",
    "  intensity reset              Remove the local intensity override",
    "  timelapse get                Print the active time-lapse cycle length",
    "  timelapse set N              Set a local cycle length in 5-minute steps",
    "  timelapse reset              Reset the time-lapse cycle length",
    "",
    "After switching, reload Ghostty config. In this setup: cmd+s then r."
  ].join("\n");
}

function configFor(name, shaderPath, overrides = {}) {
  const lines = [
    "# Generated by bin/ghostty-aurora.",
    "# Run `bin/ghostty-aurora list` for available variants.",
    `# Active variant: ${name}`
  ];

  if (overrides.intensity) {
    lines.push(`# Intensity override: ${overrides.intensity}`);
  }

  if (overrides.timelapseMinutes) {
    lines.push(`# Time-lapse minutes: ${displayMinutes(overrides.timelapseMinutes)}`);
  }

  lines.push(
    `custom-shader = ${shaderPath}`,
    "custom-shader-animation = true",
    ""
  );

  return lines.join("\n");
}

async function writeAtomic(filePath, contents) {
  await mkdir(path.dirname(filePath), { recursive: true });
  const tmpPath = `${filePath}.tmp`;
  await writeFile(tmpPath, contents);
  await rename(tmpPath, filePath);
}

function parseArgs(args) {
  const parsed = { positional: [], intensity: null, timelapseMinutes: null };

  for (let index = 0; index < args.length; index++) {
    const arg = args[index];

    if (arg === "--intensity") {
      parsed.intensity = args[index + 1] || "";
      index += 1;
    } else if (arg === "--minutes" || arg === "--timelapse-minutes") {
      parsed.timelapseMinutes = args[index + 1] || "";
      index += 1;
    } else {
      parsed.positional.push(arg);
    }
  }

  return parsed;
}

function formatIntensity(value) {
  if (typeof value !== "string" || value.trim() === "") {
    throw new Error("Intensity must be a number from 0.0 to 2.0.");
  }

  const parsed = Number(value);

  if (!Number.isFinite(parsed) || parsed < 0.0 || parsed > 2.0) {
    throw new Error("Intensity must be a number from 0.0 to 2.0.");
  }

  const rounded = Math.round(parsed * 1000) / 1000;
  return Number.isInteger(rounded) ? `${rounded}.0` : `${rounded}`;
}

function displayMinutes(value) {
  return String(Number.parseInt(value, 10));
}

function formatTimelapseMinutes(value) {
  if (typeof value !== "string" || value.trim() === "") {
    throw new Error("Time-lapse minutes must be a number from 5 to 240 in 5-minute steps.");
  }

  const parsed = Number(value);

  if (!Number.isFinite(parsed) || parsed < 5 || parsed > 240 || parsed % 5 !== 0) {
    throw new Error("Time-lapse minutes must be a number from 5 to 240 in 5-minute steps.");
  }

  return `${parsed}.0`;
}

function defaultIntensity(variant) {
  return variant.values.AURORA_INTENSITY;
}

function defaultTimelapseMinutes(variant) {
  return variant.values.TIME_LAPSE_MINUTES || "30.0";
}

function patchConstant(source, name, value) {
  const patched = source.replace(
    new RegExp(`^const float ${name} = [0-9.]+;$`, "m"),
    `const float ${name} = ${value};`
  );

  if (patched === source) {
    throw new Error(`Could not patch ${name}.`);
  }

  return patched;
}

async function patchActiveShader(variant, overrides = {}) {
  const sourcePath = path.join(root, variant.file);
  let patched = await readFile(sourcePath, "utf8");

  if (overrides.intensity) {
    patched = patchConstant(patched, "AURORA_INTENSITY", overrides.intensity);
  }

  if (overrides.timelapseMinutes) {
    patched = patchConstant(patched, "TIME_LAPSE_MINUTES", overrides.timelapseMinutes);
  }

  await writeAtomic(activeShaderPath, patched);
}

async function readConfig() {
  try {
    return await readFile(configPath, "utf8");
  } catch (error) {
    if (error.code !== "ENOENT") {
      throw error;
    }

    return "";
  }
}

function activeVariantFromConfig(config) {
  const match = config.match(/^# Active variant: (.+)$/m);
  if (match) {
    return match[1];
  }

  for (const variant of variants) {
    if (config.includes(variant.file)) {
      return variant.id;
    }
  }

  return "unknown";
}

async function activeVariant() {
  return activeVariantFromConfig(await readConfig());
}

async function activeIntensity() {
  const config = await readConfig();
  const variantName = activeVariantFromConfig(config);
  const variant = findVariant(variantName);

  if (!variant) {
    return "unknown";
  }

  if (config.includes(activeShaderPath)) {
    try {
      const activeShader = await readFile(activeShaderPath, "utf8");
      const match = activeShader.match(/^const float AURORA_INTENSITY = ([0-9.]+);$/m);

      if (match) {
        return match[1];
      }

      throw new Error(`Could not read AURORA_INTENSITY from ${activeShaderPath}.`);
    } catch (error) {
      if (error.code === "ENOENT") {
        throw new Error(
          `Active intensity override points to missing ${activeShaderPath}. Run \`bin/ghostty-aurora intensity reset\` or set a new intensity.`
        );
      }

      throw error;
    }
  }

  return defaultIntensity(variant);
}

async function activeTimelapseMinutes() {
  const config = await readConfig();
  const variantName = activeVariantFromConfig(config);
  const variant = findVariant(variantName);

  if (!variant || variant.values.TIME_LAPSE_ENABLED !== "1.0") {
    return "disabled";
  }

  if (config.includes(activeShaderPath)) {
    try {
      const activeShader = await readFile(activeShaderPath, "utf8");
      const match = activeShader.match(/^const float TIME_LAPSE_MINUTES = ([0-9.]+);$/m);

      if (match) {
        return displayMinutes(match[1]);
      }

      throw new Error(`Could not read TIME_LAPSE_MINUTES from ${activeShaderPath}.`);
    } catch (error) {
      if (error.code === "ENOENT") {
        throw new Error(
          `Active time-lapse override points to missing ${activeShaderPath}. Run \`bin/ghostty-aurora timelapse reset\` or set a new time-lapse interval.`
        );
      }

      throw error;
    }
  }

  return displayMinutes(defaultTimelapseMinutes(variant));
}

function configForVariant(name, overrides = {}) {
  const variant = findVariant(name);

  if (!variant) {
    throw new Error(`Unknown variant: ${name}`);
  }

  if (overrides.intensity || overrides.timelapseMinutes) {
    return configFor(name, activeShaderPath, overrides);
  }

  return [
    "# Generated by bin/ghostty-aurora.",
    "# Run `bin/ghostty-aurora list` for available variants.",
    `# Active variant: ${name}`,
    `custom-shader = ${path.join(root, variant.file)}`,
    "custom-shader-animation = true",
    ""
  ].join("\n");
}

async function writeConfig(name, overrides = {}) {
  const variant = findVariant(name);
  if (!variant) {
    throw new Error(`Unknown variant: ${name}`);
  }

  if (overrides.intensity || overrides.timelapseMinutes) {
    await patchActiveShader(variant, overrides);
  } else {
    await rm(activeShaderPath, { force: true });
  }

  await writeAtomic(configPath, configForVariant(name, overrides));
  return variant.file;
}

async function current() {
  return activeVariant();
}

const [, , command, ...args] = process.argv;

try {
  if (command === "list") {
    for (const variant of variants) {
      console.log(`${variant.id}\t${variant.file}`);
    }
  } else if (command === "current") {
    console.log(await current());
  } else if (command === "use") {
    const parsed = parseArgs(args);
    const name = parsed.positional[0] || "";
    if (!findVariant(name)) {
      throw new Error(`Expected one of: ${variantIds().join(", ")}`);
    }

    const intensity = parsed.intensity !== null ? formatIntensity(parsed.intensity) : null;
    const timelapseMinutes = parsed.timelapseMinutes !== null ? formatTimelapseMinutes(parsed.timelapseMinutes) : null;

    if (timelapseMinutes && name !== "timelapse") {
      throw new Error("--minutes can only be used with the timelapse variant.");
    }

    const file = await writeConfig(name, { intensity, timelapseMinutes });
    const details = [
      intensity ? `intensity ${intensity}` : "",
      timelapseMinutes ? `time-lapse ${displayMinutes(timelapseMinutes)}m` : ""
    ].filter(Boolean);
    const suffix = details.length ? ` with ${details.join(" and ")}` : "";
    console.log(`Ghostty Aurora variant set to ${name} (${file})${suffix}.`);
    console.log("Reload Ghostty config to apply it.");
  } else if (command === "intensity") {
    const [action, rawIntensity] = args;

    if (action === "get") {
      console.log(await activeIntensity());
    } else if (action === "set") {
      const name = await activeVariant();
      const variant = findVariant(name);

      if (!variant) {
        throw new Error("Set a variant before setting intensity.");
      }

      const intensity = formatIntensity(rawIntensity || "");
      await writeConfig(name, { intensity });
      console.log(`Ghostty Aurora intensity set to ${intensity} for ${name}.`);
      console.log("Reload Ghostty config to apply it.");
    } else if (action === "reset") {
      const name = await activeVariant();
      const variant = findVariant(name);

      if (!variant) {
        throw new Error("Set a variant before resetting intensity.");
      }

      await writeConfig(name);
      console.log(`Ghostty Aurora intensity reset to ${defaultIntensity(variant)} for ${name}.`);
      console.log("Reload Ghostty config to apply it.");
    } else {
      throw new Error("Expected intensity get, intensity set N, or intensity reset.");
    }
  } else if (command === "timelapse") {
    const [action, rawMinutes] = args;

    if (action === "get") {
      console.log(await activeTimelapseMinutes());
    } else if (action === "set") {
      const minutes = formatTimelapseMinutes(rawMinutes || "");
      await writeConfig("timelapse", { timelapseMinutes: minutes });
      console.log(`Ghostty Aurora time-lapse cycle set to ${displayMinutes(minutes)} minutes.`);
      console.log("Reload Ghostty config to apply it.");
    } else if (action === "reset") {
      const variant = findVariant("timelapse");
      await writeConfig("timelapse");
      console.log(`Ghostty Aurora time-lapse cycle reset to ${displayMinutes(defaultTimelapseMinutes(variant))} minutes.`);
      console.log("Reload Ghostty config to apply it.");
    } else {
      throw new Error("Expected timelapse get, timelapse set N, or timelapse reset.");
    }
  } else {
    console.log(usage());
    process.exitCode = command ? 1 : 0;
  }
} catch (error) {
  console.error(error.message);
  console.error("");
  console.error(usage());
  process.exitCode = 1;
}
