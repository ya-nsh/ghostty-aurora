#!/usr/bin/env node

import { mkdir, readFile, rename, rm, writeFile } from "node:fs/promises";
import path from "node:path";
import { fileURLToPath } from "node:url";
import { findVariant, variantIds, variants } from "../src/variants.mjs";

const root = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..");
const configDir = path.join(root, "config");
const configPath = path.join(configDir, "ghostty-aurora.conf");
const activeShaderPath = path.join(configDir, "active.glsl");

function usage() {
  const idList = variantIds().join("|");

  return [
    "Usage: ghostty-aurora <command>",
    "",
    "Commands:",
    "  list                         List available variants",
    "  current                      Print the active variant",
    `  use ${idList} [--intensity N]  Switch the Ghostty shader fragment`,
    "  intensity get                Print the active intensity",
    "  intensity set N              Set a local intensity override",
    "  intensity reset              Remove the local intensity override",
    "",
    "After switching, reload Ghostty config. In this setup: cmd+s then r."
  ].join("\n");
}

function configFor(name, shaderPath, intensity = null) {
  const lines = [
    "# Generated by bin/ghostty-aurora.",
    "# Run `bin/ghostty-aurora list` for available variants.",
    `# Active variant: ${name}`
  ];

  if (intensity) {
    lines.push(`# Intensity override: ${intensity}`);
  }

  lines.push(
    `custom-shader = ${shaderPath}`,
    "custom-shader-animation = true",
    ""
  );

  return lines.join("\n");
}

async function writeAtomic(filePath, contents) {
  await mkdir(path.dirname(filePath), { recursive: true });
  const tmpPath = `${filePath}.tmp`;
  await writeFile(tmpPath, contents);
  await rename(tmpPath, filePath);
}

function parseArgs(args) {
  const parsed = { positional: [], intensity: null };

  for (let index = 0; index < args.length; index++) {
    const arg = args[index];

    if (arg === "--intensity") {
      parsed.intensity = args[index + 1] || "";
      index += 1;
    } else {
      parsed.positional.push(arg);
    }
  }

  return parsed;
}

function formatIntensity(value) {
  if (typeof value !== "string" || value.trim() === "") {
    throw new Error("Intensity must be a number from 0.0 to 2.0.");
  }

  const parsed = Number(value);

  if (!Number.isFinite(parsed) || parsed < 0.0 || parsed > 2.0) {
    throw new Error("Intensity must be a number from 0.0 to 2.0.");
  }

  const rounded = Math.round(parsed * 1000) / 1000;
  return Number.isInteger(rounded) ? `${rounded}.0` : `${rounded}`;
}

function defaultIntensity(variant) {
  return variant.values.AURORA_INTENSITY;
}

async function patchIntensity(variant, intensity) {
  const sourcePath = path.join(root, variant.file);
  const source = await readFile(sourcePath, "utf8");
  const patched = source.replace(
    /^const float AURORA_INTENSITY = [0-9.]+;$/m,
    `const float AURORA_INTENSITY = ${intensity};`
  );

  if (patched === source) {
    throw new Error(`Could not patch AURORA_INTENSITY in ${variant.file}.`);
  }

  await writeAtomic(activeShaderPath, patched);
}

async function readConfig() {
  try {
    return await readFile(configPath, "utf8");
  } catch (error) {
    if (error.code !== "ENOENT") {
      throw error;
    }

    return "";
  }
}

function activeVariantFromConfig(config) {
  const match = config.match(/^# Active variant: (.+)$/m);
  if (match) {
    return match[1];
  }

  for (const variant of variants) {
    if (config.includes(variant.file)) {
      return variant.id;
    }
  }

  return "unknown";
}

async function activeVariant() {
  return activeVariantFromConfig(await readConfig());
}

async function activeIntensity() {
  const config = await readConfig();
  const variantName = activeVariantFromConfig(config);
  const variant = findVariant(variantName);

  if (!variant) {
    return "unknown";
  }

  if (config.includes(activeShaderPath)) {
    try {
      const activeShader = await readFile(activeShaderPath, "utf8");
      const match = activeShader.match(/^const float AURORA_INTENSITY = ([0-9.]+);$/m);

      if (match) {
        return match[1];
      }

      throw new Error(`Could not read AURORA_INTENSITY from ${activeShaderPath}.`);
    } catch (error) {
      if (error.code === "ENOENT") {
        throw new Error(
          `Active intensity override points to missing ${activeShaderPath}. Run \`bin/ghostty-aurora intensity reset\` or set a new intensity.`
        );
      }

      throw error;
    }
  }

  return defaultIntensity(variant);
}

function configForVariant(name, intensity = null) {
  const variant = findVariant(name);

  if (!variant) {
    throw new Error(`Unknown variant: ${name}`);
  }

  if (intensity) {
    return configFor(name, activeShaderPath, intensity);
  }

  return [
    "# Generated by bin/ghostty-aurora.",
    "# Run `bin/ghostty-aurora list` for available variants.",
    `# Active variant: ${name}`,
    `custom-shader = ${path.join(root, variant.file)}`,
    "custom-shader-animation = true",
    ""
  ].join("\n");
}

async function writeConfig(name, intensity = null) {
  const variant = findVariant(name);
  if (!variant) {
    throw new Error(`Unknown variant: ${name}`);
  }

  if (intensity) {
    await patchIntensity(variant, intensity);
  } else {
    await rm(activeShaderPath, { force: true });
  }

  await writeAtomic(configPath, configForVariant(name, intensity));
  return variant.file;
}

async function current() {
  return activeVariant();
}

const [, , command, ...args] = process.argv;

try {
  if (command === "list") {
    for (const variant of variants) {
      console.log(`${variant.id}\t${variant.file}`);
    }
  } else if (command === "current") {
    console.log(await current());
  } else if (command === "use") {
    const parsed = parseArgs(args);
    const name = parsed.positional[0] || "";
    if (!findVariant(name)) {
      throw new Error(`Expected one of: ${variantIds().join(", ")}`);
    }

    const intensity = parsed.intensity !== null ? formatIntensity(parsed.intensity) : null;
    const file = await writeConfig(name, intensity);
    const suffix = intensity ? ` with intensity ${intensity}` : "";
    console.log(`Ghostty Aurora variant set to ${name} (${file})${suffix}.`);
    console.log("Reload Ghostty config to apply it.");
  } else if (command === "intensity") {
    const [action, rawIntensity] = args;

    if (action === "get") {
      console.log(await activeIntensity());
    } else if (action === "set") {
      const name = await activeVariant();
      const variant = findVariant(name);

      if (!variant) {
        throw new Error("Set a variant before setting intensity.");
      }

      const intensity = formatIntensity(rawIntensity || "");
      await writeConfig(name, intensity);
      console.log(`Ghostty Aurora intensity set to ${intensity} for ${name}.`);
      console.log("Reload Ghostty config to apply it.");
    } else if (action === "reset") {
      const name = await activeVariant();
      const variant = findVariant(name);

      if (!variant) {
        throw new Error("Set a variant before resetting intensity.");
      }

      await writeConfig(name);
      console.log(`Ghostty Aurora intensity reset to ${defaultIntensity(variant)} for ${name}.`);
      console.log("Reload Ghostty config to apply it.");
    } else {
      throw new Error("Expected intensity get, intensity set N, or intensity reset.");
    }
  } else {
    console.log(usage());
    process.exitCode = command ? 1 : 0;
  }
} catch (error) {
  console.error(error.message);
  console.error("");
  console.error(usage());
  process.exitCode = 1;
}
